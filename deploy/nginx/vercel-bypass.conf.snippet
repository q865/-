# Скопировать: /etc/nginx/snippets/vercel-bypass.conf
# Секрет: Vercel → Project → Settings → Deployment Protection → Protection Bypass for Automation
# Замените YOUR_BYPASS_SECRET на сгенерированный секрет (или оставьте пустым — строку закомментируйте).

# proxy_set_header x-vercel-protection-bypass YOUR_BYPASS_SECRET;
